Output docs/assets/onboarding_demo.gif
Set FontSize 22
Set Width 1000
Set Height 800
Set Padding 30
Set Theme "Catppuccin Macchiato"

Type "gyanesh-help onboarding"
Enter

Sleep 3s
# First prompt: Press Enter to continue
Enter

Sleep 3s
# Second prompt: Would you like to install a stack right now?
Type "y"
Enter

# Now the TUI Store Picker is open!
Sleep 1.5s
Down
Sleep 1s
Down
Sleep 1s
Up
Sleep 1s
# Cancel the picker
Type "q"

# Let the rest of the onboarding sequence (Macros and LLM) automatically roll out
Sleep 6s
